<payload>&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?&gt;&lt;record_update table=&quot;sys_script_include&quot;&gt;&lt;sys_script_include action=&quot;INSERT_OR_UPDATE&quot;&gt;&lt;access&gt;public&lt;/access&gt;&lt;active&gt;true&lt;/active&gt;&lt;api_name&gt;global.UpdateSetGitExporter&lt;/api_name&gt;&lt;caller_access/&gt;&lt;client_callable&gt;false&lt;/client_callable&gt;&lt;description&gt;Exports ServiceNow Update Sets to GitHub as XML files via the GitHub Contents API.&amp;#13;
Reads update records from sys_update_xml, builds an XML document, &amp;#13;
and commits it to the configured GitHub repository.&amp;#13;
&amp;#13;
Usage: Call exportToGit(updateSetSysId, updateSetName) from Background Script or Business Rule.&amp;#13;
Related properties: update_set_exporter.github_token / owner / repo / branch&lt;/description&gt;&lt;mobile_callable&gt;false&lt;/mobile_callable&gt;&lt;name&gt;UpdateSetGitExporter&lt;/name&gt;&lt;sandbox_callable&gt;false&lt;/sandbox_callable&gt;&lt;script&gt;var UpdateSetGitExporter = Class.create();&amp;#13;
UpdateSetGitExporter.prototype = {&amp;#13;
    initialize: function() {},&amp;#13;
&amp;#13;
    exportToGit: function(updateSetSysId, updateSetName) {&amp;#13;
        gs.log(&apos;=== UpdateSetGitExporter START: &apos; + updateSetName, &apos;GitExporter&apos;);&amp;#13;
&amp;#13;
        var xmlContent = this._getUpdateSetXML(updateSetSysId);&amp;#13;
        if (!xmlContent) {&amp;#13;
            gs.logError(&apos;XML 추출 실패: &apos; + updateSetSysId, &apos;GitExporter&apos;);&amp;#13;
            return;&amp;#13;
        }&amp;#13;
        gs.log(&apos;XML 추출 성공, 길이: &apos; + xmlContent.length, &apos;GitExporter&apos;);&amp;#13;
&amp;#13;
        var encodedContent = GlideStringUtil.base64Encode(xmlContent);&amp;#13;
        this._pushToGitHub(encodedContent, updateSetName, updateSetSysId);&amp;#13;
    },&amp;#13;
&amp;#13;
    _getUpdateSetXML: function(sysId) {&amp;#13;
        try {&amp;#13;
            // Update Set 메타데이터 조회&amp;#13;
            var updateSetGR = new GlideRecord(&apos;sys_update_set&apos;);&amp;#13;
            if (!updateSetGR.get(sysId)) {&amp;#13;
                gs.logError(&apos;Update Set not found: &apos; + sysId, &apos;GitExporter&apos;);&amp;#13;
                return null;&amp;#13;
            }&amp;#13;
&amp;#13;
            var now = new GlideDateTime();&amp;#13;
            var unloadDate = now.getValue();&amp;#13;
&amp;#13;
            // &amp;lt;unload&amp;gt; 루트 태그로 시작&amp;#13;
            var xmlDoc = &apos;&amp;lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;&amp;lt;unload unload_date=&quot;&apos; + unloadDate + &apos;&quot;&amp;gt;\n&apos;;&amp;#13;
&amp;#13;
            // sys_remote_update_set 블록&amp;#13;
            xmlDoc += &apos;  &amp;lt;sys_remote_update_set action=&quot;INSERT_OR_UPDATE&quot;&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;application&amp;gt;&apos; + updateSetGR.getValue(&apos;application&apos;) + &apos;&amp;lt;/application&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;application_display_value&amp;gt;&apos; + updateSetGR.getDisplayValue(&apos;application&apos;) + &apos;&amp;lt;/application_display_value&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;description&amp;gt;&apos; + (updateSetGR.getValue(&apos;description&apos;) || &apos;&apos;) + &apos;&amp;lt;/description&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;name&amp;gt;&apos; + updateSetGR.getValue(&apos;name&apos;) + &apos;&amp;lt;/name&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;origin_sys_id&amp;gt;&apos; + sysId + &apos;&amp;lt;/origin_sys_id&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;release_date&amp;gt;&apos; + (updateSetGR.getValue(&apos;release_date&apos;) || &apos;&apos;) + &apos;&amp;lt;/release_date&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;state&amp;gt;loaded&amp;lt;/state&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;sys_class_name&amp;gt;sys_remote_update_set&amp;lt;/sys_class_name&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;sys_created_by&amp;gt;&apos; + updateSetGR.getValue(&apos;sys_created_by&apos;) + &apos;&amp;lt;/sys_created_by&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;sys_created_on&amp;gt;&apos; + updateSetGR.getValue(&apos;sys_created_on&apos;) + &apos;&amp;lt;/sys_created_on&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;sys_id&amp;gt;&apos; + sysId + &apos;&amp;lt;/sys_id&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;sys_updated_by&amp;gt;&apos; + updateSetGR.getValue(&apos;sys_updated_by&apos;) + &apos;&amp;lt;/sys_updated_by&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;    &amp;lt;sys_updated_on&amp;gt;&apos; + updateSetGR.getValue(&apos;sys_updated_on&apos;) + &apos;&amp;lt;/sys_updated_on&amp;gt;\n&apos;;&amp;#13;
            xmlDoc += &apos;  &amp;lt;/sys_remote_update_set&amp;gt;\n&apos;;&amp;#13;
&amp;#13;
            // sys_update_xml 블록 (실제 변경 내용)&amp;#13;
            var gr = new GlideRecord(&apos;sys_update_xml&apos;);&amp;#13;
            gr.addQuery(&apos;update_set&apos;, sysId);&amp;#13;
            gr.query();&amp;#13;
&amp;#13;
            while (gr.next()) {&amp;#13;
                xmlDoc += &apos;  &amp;lt;sys_update_xml action=&quot;INSERT_OR_UPDATE&quot;&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;action&amp;gt;&apos; + (gr.getValue(&apos;action&apos;) || &apos;INSERT_OR_UPDATE&apos;) + &apos;&amp;lt;/action&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;application&amp;gt;&apos; + (gr.getValue(&apos;application&apos;) || &apos;&apos;) + &apos;&amp;lt;/application&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;name&amp;gt;&apos; + gr.getValue(&apos;name&apos;) + &apos;&amp;lt;/name&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;payload&amp;gt;&amp;lt;![CDATA[&apos; + gr.getValue(&apos;payload&apos;) + &apos;]]&amp;gt;&amp;lt;/payload&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;sys_created_by&amp;gt;&apos; + gr.getValue(&apos;sys_created_by&apos;) + &apos;&amp;lt;/sys_created_by&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;sys_created_on&amp;gt;&apos; + gr.getValue(&apos;sys_created_on&apos;) + &apos;&amp;lt;/sys_created_on&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;sys_id&amp;gt;&apos; + gr.getValue(&apos;sys_id&apos;) + &apos;&amp;lt;/sys_id&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;sys_updated_by&amp;gt;&apos; + gr.getValue(&apos;sys_updated_by&apos;) + &apos;&amp;lt;/sys_updated_by&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;sys_updated_on&amp;gt;&apos; + gr.getValue(&apos;sys_updated_on&apos;) + &apos;&amp;lt;/sys_updated_on&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;target_name&amp;gt;&apos; + gr.getValue(&apos;target_name&apos;) + &apos;&amp;lt;/target_name&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;type&amp;gt;&apos; + gr.getValue(&apos;type&apos;) + &apos;&amp;lt;/type&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;    &amp;lt;update_set&amp;gt;&apos; + sysId + &apos;&amp;lt;/update_set&amp;gt;\n&apos;;&amp;#13;
                xmlDoc += &apos;  &amp;lt;/sys_update_xml&amp;gt;\n&apos;;&amp;#13;
            }&amp;#13;
&amp;#13;
            xmlDoc += &apos;&amp;lt;/unload&amp;gt;&apos;;&amp;#13;
&amp;#13;
            gs.log(&apos;XML 생성 완료, 레코드 포함&apos;, &apos;GitExporter&apos;);&amp;#13;
            return xmlDoc;&amp;#13;
&amp;#13;
        } catch (e) {&amp;#13;
            gs.logError(&apos;XML 생성 오류: &apos; + e.message, &apos;GitExporter&apos;);&amp;#13;
            return null;&amp;#13;
        }&amp;#13;
    },&amp;#13;
&amp;#13;
    _pushToGitHub: function(encodedContent, updateSetName, sysId) {&amp;#13;
        var token = gs.getProperty(&apos;update_set_exporter.github_token&apos;);&amp;#13;
        var owner = gs.getProperty(&apos;update_set_exporter.github_owner&apos;);&amp;#13;
        var repoName = gs.getProperty(&apos;update_set_exporter.github_repo&apos;);&amp;#13;
        var branch = gs.getProperty(&apos;update_set_exporter.github_branch&apos;) || &apos;main&apos;;&amp;#13;
&amp;#13;
&amp;#13;
        // 파일명 생성 (정규식 없이)&amp;#13;
        var nameClean = &apos;&apos;;&amp;#13;
        for (var j = 0; j &amp;lt; updateSetName.length; j++) {&amp;#13;
            var c = updateSetName.charAt(j);&amp;#13;
            nameClean += (c === &apos; &apos;) ? &apos;_&apos; : c;&amp;#13;
        }&amp;#13;
&amp;#13;
        var fileName = &apos;update_sets/&apos; + nameClean + &apos;.xml&apos;;&amp;#13;
&amp;#13;
        var apiUrl = &apos;https://api.github.com/repos/&apos; + owner + &apos;/&apos; + repoName + &apos;/contents/&apos; + fileName;&amp;#13;
&amp;#13;
        var existingSHA = this._getFileSHA(apiUrl, token);&amp;#13;
&amp;#13;
        var body = {&amp;#13;
            message: &apos;export: &apos; + updateSetName + &apos; (&apos; + sysId + &apos;)&apos;,&amp;#13;
            content: encodedContent,&amp;#13;
            branch: branch&amp;#13;
        };&amp;#13;
        if (existingSHA) body.sha = existingSHA;&amp;#13;
&amp;#13;
        var rm = new sn_ws.RESTMessageV2();&amp;#13;
        rm.setEndpoint(apiUrl);&amp;#13;
        rm.setHttpMethod(&apos;PUT&apos;);&amp;#13;
        rm.setRequestHeader(&apos;Authorization&apos;, &apos;token &apos; + token);&amp;#13;
        rm.setRequestHeader(&apos;Content-Type&apos;, &apos;application/json&apos;);&amp;#13;
        rm.setRequestHeader(&apos;User-Agent&apos;, &apos;ServiceNow-PDI-Exporter&apos;);&amp;#13;
        rm.setRequestBody(JSON.stringify(body));&amp;#13;
&amp;#13;
        var response = rm.execute();&amp;#13;
        var statusCode = response.getStatusCode();&amp;#13;
        var responseBody = response.getBody();&amp;#13;
&amp;#13;
        if (statusCode == 201 || statusCode == 200) {&amp;#13;
            gs.log(&apos;GitHub Push 성공! 파일: &apos; + fileName, &apos;GitExporter&apos;);&amp;#13;
        } else {&amp;#13;
            gs.logError(&apos;GitHub Push 실패 [&apos; + statusCode + &apos;]: &apos; + responseBody, &apos;GitExporter&apos;);&amp;#13;
        }&amp;#13;
    },&amp;#13;
&amp;#13;
    _getFileSHA: function(apiUrl, token) {&amp;#13;
        try {&amp;#13;
            var rm = new sn_ws.RESTMessageV2();&amp;#13;
            rm.setEndpoint(apiUrl);&amp;#13;
            rm.setHttpMethod(&apos;GET&apos;);&amp;#13;
            rm.setRequestHeader(&apos;Authorization&apos;, &apos;token &apos; + token);&amp;#13;
            rm.setRequestHeader(&apos;User-Agent&apos;, &apos;ServiceNow-PDI-Exporter&apos;);&amp;#13;
&amp;#13;
            var response = rm.execute();&amp;#13;
            if (response.getStatusCode() == 200) {&amp;#13;
                var parsed = JSON.parse(response.getBody());&amp;#13;
                return parsed.sha;&amp;#13;
            }&amp;#13;
        } catch (e) {}&amp;#13;
&amp;#13;
        return null;&amp;#13;
    },&amp;#13;

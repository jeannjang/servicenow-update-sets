<update_set>
  <record>
    <name>sys_script_include_eeb9bb2793effe10e502fbf08bba10ab</name>
    <type>Script Include</type>
    <target_name>UpdateSetGitExporter</target_name>
    <payload><![CDATA[<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_script_include"><sys_script_include action="INSERT_OR_UPDATE"><access>public</access><active>true</active><api_name>global.UpdateSetGitExporter</api_name><caller_access/><client_callable>false</client_callable><description>Exports ServiceNow Update Sets to GitHub as XML files via the GitHub Contents API.&#13;
Reads update records from sys_update_xml, builds an XML document, &#13;
and commits it to the configured GitHub repository.&#13;
&#13;
Usage: Call exportToGit(updateSetSysId, updateSetName) from Background Script or Business Rule.&#13;
Related properties: update_set_exporter.github_token / owner / repo / branch</description><mobile_callable>false</mobile_callable><name>UpdateSetGitExporter</name><sandbox_callable>false</sandbox_callable><script>var UpdateSetGitExporter = Class.create();&#13;
UpdateSetGitExporter.prototype = {&#13;
    initialize: function() {},&#13;
&#13;
    exportToGit: function(updateSetSysId, updateSetName) {&#13;
        gs.log('=== UpdateSetGitExporter START: ' + updateSetName, 'GitExporter');&#13;
&#13;
        var xmlContent = this._getUpdateSetXML(updateSetSysId);&#13;
        if (!xmlContent) {&#13;
            gs.logError('XML 추출 실패: ' + updateSetSysId, 'GitExporter');&#13;
            return;&#13;
        }&#13;
        gs.log('XML 추출 성공, 길이: ' + xmlContent.length, 'GitExporter');&#13;
&#13;
        var encodedContent = GlideStringUtil.base64Encode(xmlContent);&#13;
        this._pushToGitHub(encodedContent, updateSetName, updateSetSysId);&#13;
    },&#13;
&#13;
    _getUpdateSetXML: function(sysId) {&#13;
        try {&#13;
            var gr = new GlideRecord('sys_update_xml');&#13;
            gr.addQuery('update_set', sysId);&#13;
            gr.query();&#13;
&#13;
            var xmlDoc = '&lt;update_set&gt;\n';&#13;
            while (gr.next()) {&#13;
                xmlDoc += '  &lt;record&gt;\n';&#13;
                xmlDoc += '    &lt;name&gt;' + gr.getValue('name') + '&lt;/name&gt;\n';&#13;
                xmlDoc += '    &lt;type&gt;' + gr.getValue('type') + '&lt;/type&gt;\n';&#13;
                xmlDoc += '    &lt;target_name&gt;' + gr.getValue('target_name') + '&lt;/target_name&gt;\n';&#13;
                xmlDoc += '    &lt;payload&gt;&lt;![CDATA[' + gr.getValue('payload') + ']]&gt;&lt;/payload&gt;\n';&#13;
                xmlDoc += '  &lt;/record&gt;\n';&#13;
            }&#13;
            xmlDoc += '&lt;/update_set&gt;';&#13;
            return xmlDoc;&#13;
        } catch (e) {&#13;
            gs.logError('XML 생성 오류: ' + e.message, 'GitExporter');&#13;
            return null;&#13;
        }&#13;
    },&#13;
&#13;
    _pushToGitHub: function(encodedContent, updateSetName, sysId) {&#13;
        var token = gs.getProperty('update_set_exporter.github_token');&#13;
        var owner = gs.getProperty('update_set_exporter.github_owner');&#13;
        var repoName = gs.getProperty('update_set_exporter.github_repo');&#13;
        var branch = gs.getProperty('update_set_exporter.github_branch') || 'main';&#13;
&#13;
&#13;
        // 파일명 생성 (정규식 없이)&#13;
        var nameClean = '';&#13;
        for (var j = 0; j &lt; updateSetName.length; j++) {&#13;
            var c = updateSetName.charAt(j);&#13;
            nameClean += (c === ' ') ? '_' : c;&#13;
        }&#13;
&#13;
        var fileName = 'update_sets/' + nameClean + '.xml';&#13;
&#13;
        var apiUrl = 'https://api.github.com/repos/' + owner + '/' + repoName + '/contents/' + fileName;&#13;
&#13;
        var existingSHA = this._getFileSHA(apiUrl, token);&#13;
&#13;
        var body = {&#13;
            message: 'export: ' + updateSetName + ' (' + sysId + ')',&#13;
            content: encodedContent,&#13;
            branch: branch&#13;
        };&#13;
        if (existingSHA) body.sha = existingSHA;&#13;
&#13;
        var rm = new sn_ws.RESTMessageV2();&#13;
        rm.setEndpoint(apiUrl);&#13;
        rm.setHttpMethod('PUT');&#13;
        rm.setRequestHeader('Authorization', 'token ' + token);&#13;
        rm.setRequestHeader('Content-Type', 'application/json');&#13;
        rm.setRequestHeader('User-Agent', 'ServiceNow-PDI-Exporter');&#13;
        rm.setRequestBody(JSON.stringify(body));&#13;
&#13;
        var response = rm.execute();&#13;
        var statusCode = response.getStatusCode();&#13;
        var responseBody = response.getBody();&#13;
&#13;
        if (statusCode == 201 || statusCode == 200) {&#13;
            gs.log('GitHub Push 성공! 파일: ' + fileName, 'GitExporter');&#13;
        } else {&#13;
            gs.logError('GitHub Push 실패 [' + statusCode + ']: ' + responseBody, 'GitExporter');&#13;
        }&#13;
    },&#13;
&#13;
    _getFileSHA: function(apiUrl, token) {&#13;
        try {&#13;
            var rm = new sn_ws.RESTMessageV2();&#13;
            rm.setEndpoint(apiUrl);&#13;
            rm.setHttpMethod('GET');&#13;
            rm.setRequestHeader('Authorization', 'token ' + token);&#13;
            rm.setRequestHeader('User-Agent', 'ServiceNow-PDI-Exporter');&#13;
&#13;
            var response = rm.execute();&#13;
            if (response.getStatusCode() == 200) {&#13;
                var parsed = JSON.parse(response.getBody());&#13;
                return parsed.sha;&#13;
            }&#13;
        } catch (e) {}&#13;
        return null;&#13;
    },&#13;
&#13;
    type: 'UpdateSetGitExporter'&#13;
};</script><sys_class_name>sys_script_include</sys_class_name><sys_created_by>admin</sys_created_by><sys_created_on>2026-03-17 07:53:34</sys_created_on><sys_id>eeb9bb2793effe10e502fbf08bba10ab</sys_id><sys_mod_count>4</sys_mod_count><sys_name>UpdateSetGitExporter</sys_name><sys_package display_value="Global" source="global">global</sys_package><sys_policy/><sys_scope display_value="Global">global</sys_scope><sys_update_name>sys_script_include_eeb9bb2793effe10e502fbf08bba10ab</sys_update_name><sys_updated_by>admin</sys_updated_by><sys_updated_on>2026-03-17 08:52:07</sys_updated_on></sys_script_include><sys_es_latest_script action="INSERT_OR_UPDATE"><id>eeb9bb2793effe10e502fbf08bba10ab</id><sys_created_by>admin</sys_created_by><sys_created_on>2026-03-17 07:53:34</sys_created_on><sys_id>146a332793effe10e502fbf08bba1082</sys_id><sys_mod_count>2</sys_mod_count><sys_updated_by>admin</sys_updated_by><sys_updated_on>2026-03-17 08:09:45</sys_updated_on><table>sys_script_include</table><use_es_latest>true</use_es_latest></sys_es_latest_script></record_update>]]></payload>
  </record>
</update_set>